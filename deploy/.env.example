# Copy to .env and edit. Used by deploy/docker-compose.yml.

# Your wildcard domain suffix. Requests to <app>.tela.example.com resolve the
# TELA app whose dURL / alias is <app>. Must start with a dot.
TELA_HOST_SUFFIX=.tela.example.com

# Email for Let's Encrypt (ACME) registration.
ACME_EMAIL=admin@example.com

# DERO daemon endpoints, comma-separated, tried in order. The gateway probes
# each with DERO.GetInfo and fails over automatically. Public nodes shown; add
# your own node first if you run one.
DERO_DAEMON_URLS=node.derofoundation.org:11012,dero.rabidmining.com:10102,dero-node.net:10102,community-pools.mysrv.cloud:10102

# Subdomains that are NOT TELA apps (reserved). Comma-separated. "status" is the
# built-in status/landing page.
RESERVED_APPS=status

# Optional: pin extra app aliases (highest priority, no chain scan needed).
# name=scid,name2=scid2
TELA_ALIASES=
